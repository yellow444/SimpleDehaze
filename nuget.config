<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <!-- Public feed: managed Emgu.CV + the NVIDIA CUDA redistributables (cuda.rt/blas/npp/fft, cuDNN, msvc, zlib) -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!-- Local feed: the Emgu CUDA-OpenCV runtime 4.8.0.5324 + the two sub-packages that Emgu removed from nuget.org
         (Emgu.runtime.windows.cuda.blas.lt 12.0.104 and Emgu.runtime.windows.cuda.dnn.cnn.infer 8.8.0).
         These .nupkg files are required for the GPU build and are not available publicly. -->
    <add key="local-emgu-cuda" value=".\localpackages" />
  </packageSources>
</configuration>
